<% layout("/layouts/boilerplate.ejs") %>

  <body>


    
    <div class="row">
      <div class="col-lg-4 col-md-6 col-sm-12 mb-4">
    <div class="show-out">
      <div class="show-r">
        <br /><br />
        <h1><b>
            <%= listing.title %>
          </b></h1>

        <div class="card-r">
          <img src="<%= listing.image.url %>" class="card-img-top mb-3 img-fluid" f alt="..." style="height: 20rem" />
          <div class="">
            <h3 class="show_title" style="font-size: 900; font-weight: 400"></h3>
            <br />
            <p>Owned by: <i>
               <%= listing.owner && listing.owner.username ? listing.owner.username : "Unknown User" %>
              </i></p>
            <p>
              <%= listing.description %>
            </p>
            <p>
              &#8377; <%= listing.price ? listing.price.toLocaleString('en-IN') : 'n/a' %>/night
            </p>
            <p>
              <%= listing.location %>
            </p>
            <p>
              <%= listing.country %>
            </p>
          </div>
        </div>
      </div>

      <br><br>

      <% if (currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
      <div class="btns">
       
        <div class="btn btn-danger"><a style="text-decoration: none; color: white"
            href="/listings/<%= listing._id %>/edit">Edit</a></div>

        <br /><br />
        <form method="post" action="/listings/<%= listing._id %>?_method=delete">
          <button class="btn btn-dark">Delete</button>
        </form>
      </div>
      <% } %>
    </div>

    <br>

    <% if (currUser) {%>
    <div class="row">
      <div class="">
        <h4 class="mb-3">Leave a Comment</h4>
        <form action="/listings/<%= listing._id %>/review" novalidate class="needs-validation" method="post">
          <!-- <div>
            
            
          </div> -->
          <div>
            <label for="rating" class="form-label">Rating</label>
            <fieldset class="starability-slot">
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>
          <div>
            <label for="comment" class="form-label">Comments</label>
            <textarea name="review[comment]" required id="comment" cols="30" rows="5" class="form-control"></textarea>
            <div class="invalid-feedback">Please enter comments to submit review</div>
          </div>

          <button class="btn btn-outline-dark mt-3 mb-3">Submit</button>
        </form>
      </div>
      <hr>

      <% } %>

      <% if (!currUser)  {%>
        <div>
          <p>Login to create reviews</p>
        </div>
      <% } %>

      <br>

      <p><b>All Reviews:</b></p>
      

      <div class="row">
        <% for (review of listing.reviews) { %>
          
          <div class="card col-6 mb-3 col-lg-4 col-md-6 col-sm-12 mb-4" style="gap: 1rem;">
            <div class="card-body ">
              <h5 class="card-title">@<%= review.author ? review.author.username : "Anonymous" %></h5>
              <div class="card-text">
                <%= review.comment %>
              </div>
              <div class="card-text">
                 <p class="starability-result card-text" data-rating=<%= review.rating %>></p>
              </div>
              <form action="/listings/<%= listing._id %>/review/<%= review._id %>?_method=delete" method="post"
                class="mt-3">
                <button class="btn btn-sm btn-danger">Delete</button>
              </form>
            </div>

          </div>
          <% } %>
      </div>
    </div>

      </div>
    </div>


    

  </body>